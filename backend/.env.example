APP_NAME=Project Atlas API
APP_ENV=dev
APP_PORT=8000
DATABASE_URL=postgresql+psycopg://atlas:atlas@localhost:5432/atlas
CORS_ALLOW_ORIGINS=http://localhost:5173
JWT_SECRET=replace-with-dev-secret
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=120
PHONE_LOOKUP_SECRET=replace-with-dev-phone-secret
